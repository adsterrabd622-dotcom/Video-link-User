rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    match /videos/{videoId} {
      allow read: if true;
      allow update: if true; // Allows updating likes and views
      allow create: if true; // Allows Admin panel to create if using client API
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if true; // In a real app we'd need custom tokens to verify Telegram Auth
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if true; // Frontend initializes missing settings 
    }

    match /withdrawals/{withdrawalId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
